#!/bin/sh
#
# apk-backup - back up and restore the explicitly installed apk package set
#
# Backs up /etc/apk/world, the file apk itself uses to track only the
# explicitly requested top-level packages (not packages that were merely
# pulled in as dependencies). On restore, apk resolves dependencies fresh
# against the repos of the running release, so packages that are no longer
# needed in a newer release are not force-installed.
#
# Lives under /etc/config/ so it survives sysupgrade backups
# (hidden filename so uci does not try to parse it as a config).
#
# Usage:
#   .apk-backup -b|--backup|backup     save /etc/apk/world to .apk-backup.out
#   .apk-backup -r|--restore|restore   install all packages listed in .apk-backup.out
#   .apk-backup -h|--help|help         show this help

WORLD="/etc/apk/world"
OUT="/etc/config/.apk-backup.out"

usage() {
	cat <<-EOF
	Usage: $0 {-b|--backup|backup | -r|--restore|restore | -h|--help|help}

	  -b, --backup, backup    Save the explicitly installed packages from
	                            $WORLD
	                          to:
	                            $OUT

	  -r, --restore, restore  Install every package listed in:
	                            $OUT
	                          (useful after a reflash/reset; apk resolves
	                          dependencies fresh against the current release)

	  -h, --help, help        Show this help text
	EOF
}

cmd_backup() {
	if ! command -v apk >/dev/null 2>&1; then
		echo "Error: 'apk' command not found. This script requires an apk-based OpenWrt system (23.05+)." >&2
		exit 1
	fi
	if [ ! -s "$WORLD" ]; then
		echo "Error: $WORLD not found or empty." >&2
		exit 1
	fi
	cp "$WORLD" "$OUT"
	count=$(wc -l < "$OUT")
	echo "Saved $count package names from $WORLD to $OUT"
}

cmd_restore() {
	if ! command -v apk >/dev/null 2>&1; then
		echo "Error: 'apk' command not found. This script requires an apk-based OpenWrt system (23.05+)." >&2
		exit 1
	fi
	if [ ! -s "$OUT" ]; then
		echo "Error: $OUT not found or empty. Run 'backup' first (on the source device)." >&2
		exit 1
	fi
	echo "Installing $(wc -l < "$OUT") packages from $OUT ..."
	xargs apk add < "$OUT"
}

case "$1" in
	-b|--backup|backup)
		cmd_backup
		;;
	-r|--restore|restore)
		cmd_restore
		;;
	-h|--help|help|"")
		usage
		;;
	*)
		echo "Unknown option: $1" >&2
		usage
		exit 1
		;;
esac
